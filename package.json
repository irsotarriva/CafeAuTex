{
  "name": "cafe-autex",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first WYSIWYG LaTeX editor with real-time collaboration and AI completion",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "preview": "vite preview",
    "vite:dev": "vite --mode tauri",
    "vite:build": "tsc && vite build --mode tauri",
    "web:dev": "vite --mode web",
    "web:build": "tsc && vite build --mode web",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.3.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "katex": "^0.16.11",
    "lucide-react": "^0.469.0",
    "mathquill": "^0.10.1",
    "pdfjs-dist": "^4.9.155",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.23.0",
    "prosemirror-schema-list": "^1.4.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.37.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "y-prosemirror": "^1.3.4",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.22",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
